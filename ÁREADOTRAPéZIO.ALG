Algoritmo "ÁreadoTrapézio"
// Disciplina  : [Lógica de Programaçăo com Visualg]
// Professor   : Jailson costa dos santos
// Descriçăo   : Solicita a Área do Losango
// Autor(a)    : Victor mariano fidelis silva
// Data atual  : 27/03/2026
Var
// Seçăo de Declaraçőes das variáveis
basemaior : real
basemenor:real
altura:real
area: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreva("Digite Área do Trapézio maior : ")
leia(basemaior)
escreva("Digite Área do Trapézio menor : ")
leia(basemenor)
escreva("Digite a altura: ")
leia(altura)
area<-(basemaior+basemenor)*altura /2
escreva("O valor da área do Trapézio calculado é : ", area)

Fimalgoritmo